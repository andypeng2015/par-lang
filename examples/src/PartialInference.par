module PartialInference

import {
  @core/Bytes
  @core/List
}

dec Map : <a>[List<a>] <b>[box [a] b] List<b>
def Map = <a>[list] <b>[f] list.begin.case {
  .end! => .end!,
  .item(x) xs => .item(f(x)) xs.loop,
}

dec SortBy : <a: box>[List<a>] <k: data>[box [a] k] List<a>
def SortBy = <a: box>[list] <k: data>[key] list->List.SortBy(key)

def Strings = {*(1, 2, 3, 4, 5)}->Map(box [x] `#{x}`)
def Sorted = Strings->SortBy(box [s] s->Bytes.Length)
